+import os
+from typing import Tuple, Optional
+from .cache import get as cache_get, set as cache_set
+
+_BACKEND = os.getenv("ECL_EMBED_BACKEND", "sentence-transformers").lower()
+_ST_MODEL = os.getenv("ECL_EMBED_MODEL", "all-MiniLM-L6-v2")
+_OA_EMBED_MODEL = os.getenv("OPENAI_EMBED_MODEL", "text-embedding-3-small")
+
+_TH_EQ = 0.95
+_TH_REL = 0.85
+
+_st_model = None
+_oa_client = None
+
+def _ensure_backends():
+    global _st_model, _oa_client
+    if _BACKEND == "sentence-transformers" and _st_model is None:
+        from sentence_transformers import SentenceTransformer
+        _st_model = SentenceTransformer(_ST_MODEL)
+    elif _BACKEND == "openai" and _oa_client is None:
+        from openai import OpenAI
+        _oa_client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))
+
+def _embed(texts):
+    key = ("embed", _BACKEND, texts)
+    hit = cache_get("embeddings", key)
+    if hit is not None:
+        return hit
+    if _BACKEND == "sentence-transformers":
+        _ensure_backends()
+        vecs = _st_model.encode(texts, normalize_embeddings=True).tolist()
+    elif _BACKEND == "openai":
+        _ensure_backends()
+        out = _oa_client.embeddings.create(
+            model=_OA_EMBED_MODEL, input=texts
+        )
+        vecs = [d.embedding for d in out.data]
+    else:
+        # deterministic stub
+        vecs = [[0.0, 1.0]] * len(texts)
+    cache_set("embeddings", key, vecs)
+    return vecs
+
+def _cos(u, v):
+    # u and v are normalized when ST backend; for OA compute explicitly
+    import math
+    s = sum(ux*vx for ux, vx in zip(u, v))
+    if _BACKEND == "openai":
+        nu = math.sqrt(sum(ux*ux for ux in u)) or 1.0
+        nv = math.sqrt(sum(vx*vx for vx in v)) or 1.0
+        s = s/(nu*nv)
+    return max(min(s, 1.0), -1.0)
+
+def classify_similarity(a: str, b: str) -> Tuple[str, float]:
+    """
+    Embedding-based semantic similarity with thresholds:
+    - cosine >= 0.95 => 'equivalent'
+    - 0.85..0.95     => 'related'
+    - else           => 'different'
+    """
+    a = (a or "").strip()
+    b = (b or "").strip()
+    if not a or not b:
+        return ("different", 0.0)
+    vecs = _embed([a, b])
+    sim = _cos(vecs[0], vecs[1])
+    if sim >= _TH_EQ:
+        return ("equivalent", float(sim))
+    if sim >= _TH_REL:
+        return ("related", float(sim))
+    return ("different", float(sim))

