# Example environment variables for real adapters
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Embedding backend: "openai" or "sentence-transformers" 
ECL_EMBED_BACKEND=sentence-transformers

# Local model configuration (Ollama recommended)
ECL_LOCAL_MODEL=ollama:llama3.1:8b
ECL_OLLAMA_BASE_URL=http://localhost:11434

# Cache configuration
ECL_CACHE_DIR=.ecl_cache
ECL_CACHE_TTL_HOURS=24

# Rate limiting
ECL_RATE_LIMIT_RPM=60