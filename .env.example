# Provider API keys (optional for local dev; CI stays mocked)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Similarity backend: "sentence-transformers" | "openai" | "stub"
ECL_EMBED_BACKEND=stub

# Cache
ECL_CACHE_TTL_HOURS=4

# Local model configuration (Ollama recommended)
ECL_LOCAL_MODEL=ollama:llama3.1:8b
ECL_OLLAMA_BASE_URL=http://localhost:11434

# Rate limiting
ECL_RATE_LIMIT_RPM=60