# Provider API keys (optional; stubs used if missing)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Embeddings backend: sentence-transformers|openai|stub
# Default to sentence-transformers for semantic similarity
ECL_EMBED_BACKEND=sentence-transformers
# Sentence-Transformers model (defaults to all-MiniLM-L6-v2)
ECL_ST_MODEL=all-MiniLM-L6-v2
# OpenAI embedding model (if ECL_EMBED_BACKEND=openai)
ECL_OPENAI_EMBED_MODEL=text-embedding-3-small

# Cache
ECL_CACHE_TTL_HOURS=4
ECL_POLICY_FILE=policies/providers.yml
ECL_DEFAULT_TIMEOUT_S=8.0
ECL_MAX_TIMEOUT_S=60.0
ECL_MAX_PROMPT_LENGTH=10000

# Local model configuration (Ollama recommended)
ECL_LOCAL_MODEL=ollama:llama3.1:8b
ECL_OLLAMA_BASE_URL=http://localhost:11434

# Rate limiting
ECL_RATE_LIMIT_RPM=60
ECL_RATE_LIMIT_BURST=10
ECL_RATE_LIMIT_KEY_STRATEGY=ip

# API authentication
ECL_AUTH_MODE=off
ECL_API_KEYS=
