+import numpy as np
+from src.ecl.calibration.isotonic import IsotonicCalibrator
+from src.ecl.calibration.platt import PlattCalibrator
+from src.ecl.metrics.calibration import ece  # assuming this exists already in repo
+
+def test_isotonic_calibration_monotonic():
+    scores = np.linspace(0.0, 1.0, 20)
+    labels = (scores > 0.5).astype(int)
+    iso = IsotonicCalibrator().fit(scores, labels)
+    preds = iso.predict(scores)
+    # Monotonicity
+    assert (np.diff(preds) >= -1e-6).all()
+
+def test_platt_calibration_bounds():
+    scores = np.linspace(0.0, 1.0, 50)
+    labels = (scores > 0.6).astype(int)
+    pl = PlattCalibrator().fit(scores, labels)
+    preds = pl.predict(np.array([0.0, 0.5, 1.0]))
+    assert (preds >= 0.0).all() and (preds <= 1.0).all()
