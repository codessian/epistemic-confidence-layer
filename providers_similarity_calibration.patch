+from __future__ import annotations
+import numpy as np
+from sklearn.linear_model import LogisticRegression
+
+class PlattCalibrator:
+    def __init__(self) -> None:
+        self._lr = LogisticRegression(solver="lbfgs")
+        self._fitted = False
+
+    def fit(self, scores: np.ndarray, labels: np.ndarray) -> "PlattCalibrator":
+        scores = np.asarray(scores, dtype=np.float32).reshape(-1, 1)
+        labels = np.asarray(labels, dtype=np.int32)
+        self._lr.fit(scores, labels)
+        self._fitted = True
+        return self
+
+    def predict(self, scores: np.ndarray) -> np.ndarray:
+        if not self._fitted:
+            raise RuntimeError("PlattCalibrator not fitted")
+        scores = np.asarray(scores, dtype=np.float32).reshape(-1, 1)
+        proba = self._lr.predict_proba(scores)[:, 1]
+        return proba.astype(np.float32)
+
