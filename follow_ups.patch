+        uses: actions/github-script@v7
+        with:
+          script: |
+            const fs = require('fs');
+            const core = require('@actions/core');
+            try {
+              const metrics = JSON.parse(fs.readFileSync('benchmarks/results/metrics.json','utf8'));
+              const title = `Nightly ECE ${new Date().toISOString().slice(0,10)}`;
+              const bodies = [
+                `**ECE (before → after):** ${metrics.ece_before?.toFixed(3)} → ${metrics.ece_after?.toFixed(3)}`,
+                `**Samples:** ${metrics.n_samples}`,
+                `Artifacts: attached to workflow run.`,
+              ].join('\\n');
+              // Get a category (fall back to first)
+              const { repository } = await github.graphql(`
+                query($owner:String!, $name:String!) {
+                  repository(owner:$owner, name:$name) {
+                    discussionCategories(first:10){ nodes { id, name } }
+                  }
+                }`,
+                { owner: context.repo.owner, name: context.repo.repo }
+              );
+              const cat = repository.discussionCategories?.nodes?.[0];
