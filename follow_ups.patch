+            --out-csv benchmarks/trends/ece_trend.csv
+          python .github/scripts/plot_trend.py \
+            --csv benchmarks/trends/ece_trend.csv \
+            --out benchmarks/trends/ece_trend.png
+      - name: Upload artifacts
+        uses: actions/upload-artifact@v4
+        with:
