+      - name: Install deps
+        run: |
+          python -m pip install -U pip
+          pip install -r requirements.txt -r requirements-dev.txt
+      - name: Run toy evaluation
+        run: |
+          make evaluate
+          test -f benchmarks/results/metrics.json
+      - name: Prepare trend data
+        run: |
+          mkdir -p benchmarks/trends
+          python .github/scripts/update_trend.py \
