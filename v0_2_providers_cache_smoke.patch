+name: Providers Smoke Test
+on:
+  workflow_dispatch: {}
+  push:
+    branches: [ main ]
+    paths:
+      - 'src/ecl/adapters/**'
+      - 'src/ecl/cache.py'
+      - 'scripts/smoke_providers.py'
+      - '.github/workflows/providers-smoke.yml'
+  schedule:
+    - cron: '17 3 * * *'  # daily, off-peak
+jobs:
+  smoke:
+    runs-on: ubuntu-latest
+    timeout-minutes: 10
+    strategy:
+      fail-fast: false
+      matrix:
+        provider: [stub, openai, anthropic]
+    steps:
+      - uses: actions/checkout@v4
+      - uses: actions/setup-python@v5
+        with:
+          python-version: '3.11'
+      - name: Install deps
+        run: |
+          python -m pip install --upgrade pip
+          pip install -r requirements.txt -r requirements-dev.txt
+      - name: Export secrets (if present)
+        env:
+          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
+          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
+        run: |
+          echo "ECL_SMOKE_TARGETS=${{ matrix.provider }}" >> $GITHUB_ENV
+          echo "ECL_SMOKE_TIMEOUT_S=5.0" >> $GITHUB_ENV
+          echo "ECL_CACHE_TTL_HOURS=12" >> $GITHUB_ENV
+      - name: Run smoke
+        id: smoke
+        run: |
+          python scripts/smoke_providers.py | tee smoke.json
+          echo "json<<EOF" >> $GITHUB_OUTPUT
+          cat smoke.json >> $GITHUB_OUTPUT
+          echo "EOF" >> $GITHUB_OUTPUT
+      - name: Upload artifacts
+        uses: actions/upload-artifact@v4
+        with:
+          name: providers-smoke-${{ matrix.provider }}
+          path: |
+            benchmarks/smoke/providers.json
+            benchmarks/smoke/summary.md
+      - name: Job summary
+        run: |
+          echo "## Providers Smoke (${{ matrix.provider }})" >> $GITHUB_STEP_SUMMARY
+          test -f benchmarks/smoke/summary.md && cat benchmarks/smoke/summary.md >> $GITHUB_STEP_SUMMARY || echo "_No summary produced._" >> $GITHUB_STEP_SUMMARY
