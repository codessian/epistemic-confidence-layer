+from typing import Protocol, runtime_checkable, Any, Dict, Tuple
+from ..cache import get as cache_get, set as cache_set
 
 @runtime_checkable
 class BaseAdapter(Protocol):
     name: str
     def available(self) -> bool: ...
     def generate(self, prompt: str, **kwargs: Any) -> str: ...
 
 @dataclass
 class AdapterRegistry:
     _reg: Dict[str, BaseAdapter]
@@
     def register(self, adapter: BaseAdapter) -> None:
         self._reg[adapter.name] = adapter
     def get(self, name: str) -> BaseAdapter:
         return self._reg[name]
     def list(self) -> Dict[str, BaseAdapter]:
         return dict(self._reg)
 
 registry = AdapterRegistry(_reg={})
 
+def _cache_key(prompt: str, kwargs: Dict[str, Any]) -> Tuple[Any, ...]:
+    # Only include stable/low-entropy params
+    allow = ("model", "temperature", "max_tokens", "top_p")
+    filtered = {k: v for k, v in kwargs.items() if k in allow and v is not None}
+    return (prompt, tuple(sorted(filtered.items())))
+
+def generate_with_cache(adapter: BaseAdapter, prompt: str, **kwargs: Any) -> str:
+    """
+    Wrap adapter.generate with a simple TTL cache.
+    Namespace is adapter.name.
+    """
+    key = _cache_key(prompt, kwargs)
+    hit = cache_get(adapter.name, key)
+    if hit is not None:
+        return hit
+    out = adapter.generate(prompt, **kwargs)
+    cache_set(adapter.name, key, out)
+    return out
+
