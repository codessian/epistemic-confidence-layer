{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ECL Verify Response",
  "type": "object",
  "required": ["ecs", "claims", "consensus", "provenance", "timing_ms"],
  "properties": {
    "ecs": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "support": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "consensus": {
      "type": "object",
      "required": ["models", "score", "details"],
      "properties": {
        "models": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "details": { "type": "array", "items": { "type": "object" } }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["prov_json", "hash_version"],
      "properties": {
        "prov_json": { "type": "object" },
        "hash_version": { "type": "string" }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "retry_after_ms": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "timing_ms": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "adapters": { "type": "object" }
      }
    },
    "x_schema_version": { "type": ["string", "null"] }
  }
}