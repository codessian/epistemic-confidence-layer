{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VerifyResponse",
  "type": "object",
  "required": ["x_schema_version", "request_id", "ecs", "claims", "consensus", "provenance", "errors", "timing_ms"],
  "properties": {
    "x_schema_version": {"type": "string", "const": "1.2"},
    "request_id": {"type": "string"},
    "route_id": {"type": ["string", "null"]},
    "ecs": {"type": "number", "minimum": 0, "maximum": 1},
    "claims": {
      "type": "array",
      "items": {"type": "object", "required": ["text"], "properties": {"text": {"type": "string"}}, "additionalProperties": false}
    },
    "consensus": {
      "type": "object",
      "required": ["score", "details", "models"],
      "properties": {
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "details": {"type": "object"},
        "models": {"type": "array", "items": {"type": ["string", "null"]}}
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": ["prov_json", "hash_version"],
      "properties": {
        "prov_json": {"type": "object"},
        "hash_version": {"type": "string"}
      },
      "additionalProperties": false
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider_id", "provider_kind", "model", "code", "message", "retryable"],
        "properties": {
          "provider_id": {"type": "string"},
          "provider_kind": {"type": "string"},
          "model": {"type": "string"},
          "code": {"type": "string"},
          "message": {"type": "string"},
          "retryable": {"type": "boolean"},
          "retry_after_ms": {"type": ["integer", "null"], "minimum": 0}
        },
        "additionalProperties": false
      }
    },
    "timing_ms": {
      "type": "object",
      "required": ["total"],
      "properties": {"total": {"type": "integer", "minimum": 0}},
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
